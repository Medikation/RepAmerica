{%- liquid
  assign og_title = page_title | default: shop.name
  assign og_url = canonical_url | default: request.origin
  assign og_type = 'website'
  assign og_description = page_description | default: shop.description | default: shop.name

  if request.page_type == 'product'
    assign og_type = 'product'
  elsif request.page_type == 'article'
    assign og_type = 'article'
  elsif request.page_type == 'password'
    assign og_url = request.origin
  endif

  # A per-page image chosen in Theme Settings > Social sharing images takes
  # priority over anything else. Shopify's own "page_image" global (native
  # image for products/articles/collections, and apparently also a default
  # for plain Pages/homepage) is used as a secondary fallback, then the
  # general fallback image is the last resort.
  assign custom_share_image = blank
  assign share_image_url = blank

  assign current_page_handle = ''
  if request.page_type == 'page'
    assign current_page_handle = page.handle
  endif

  if request.page_type == 'index'
    assign custom_share_image = settings.share_image_home
  elsif current_page_handle == 'about'
    assign custom_share_image = settings.share_image_about
  elsif current_page_handle == 'great-books-project'
    assign custom_share_image = settings.share_image_great_books
  elsif current_page_handle == 'shop'
    assign custom_share_image = settings.share_image_workshop
  elsif current_page_handle == 'watch'
    assign share_image_url = settings.share_image_watch_url
  endif

  assign share_image = custom_share_image | default: page_image | default: settings.share_image_fallback
%}

<meta property="og:site_name" content="{{ shop.name }}">
<meta property="og:url" content="{{ og_url }}">
<meta property="og:title" content="{{ og_title | escape }}">
<meta property="og:type" content="{{ og_type }}">
<meta property="og:description" content="{{ og_description | escape }}">

{%- if share_image_url != blank -%}
  <meta property="og:image" content="{{ share_image_url }}">
  <meta property="og:image:secure_url" content="{{ share_image_url }}">
{%- elsif share_image -%}
  <meta property="og:image" content="http:{{ share_image | image_url }}">
  <meta property="og:image:secure_url" content="https:{{ share_image | image_url }}">
  <meta property="og:image:width" content="{{ share_image.width }}">
  <meta property="og:image:height" content="{{ share_image.height }}">
{%- endif -%}

{%- if request.page_type == 'product' -%}
  <meta property="og:price:amount" content="{{ product.price | money_without_currency | strip_html }}">
  <meta property="og:price:currency" content="{{ cart.currency.iso_code }}">
{%- endif -%}

{%- if settings.social_twitter_link != blank -%}
  <meta name="twitter:site" content="{{ settings.social_twitter_link | split: 'twitter.com/' | last | prepend: '@' }}">
{%- endif -%}
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ og_title | escape }}">
<meta name="twitter:description" content="{{ og_description | escape }}">
