{%- style -%}
  #ContactHero-{{ section.id }} {
    padding-bottom: var(--ra-space-lg);
  }

  #ContactHero-{{ section.id }} .ra-section-header {
    margin-bottom: 0;
  }
{%- endstyle -%}

<section class="ra-section ra-contact-hero" id="ContactHero-{{ section.id }}">
  <div class="ra-container">
    <div class="ra-section-header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="ra-section-header__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}
      <h1 class="ra-section-header__title">{{ section.settings.heading | escape }}</h1>
      {%- if section.settings.text != blank -%}
        <div class="ra-section-header__text">{{ section.settings.text }}</div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Contact hero",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow / kicker",
      "default": "Media • Partnerships • Collaboration"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Contact Rep America"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Intro text (optional)",
      "info": "Leave blank if the intro copy below already covers this."
    }
  ],
  "presets": [
    {
      "name": "Contact hero"
    }
  ]
}
{% endschema %}
