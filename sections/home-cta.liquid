{{ 'rep-america-about.css' | asset_url | stylesheet_tag }}

{%- comment -%}
  Shares the About page's CTA styling, but the red band on the homepage was carrying far more
  air than it needed — clamp(72px, 10vw, 150px) top and bottom. Tightened here only, scoped to
  `.ra-home-cta`, so the About page's own closing CTA is untouched.
{%- endcomment -%}
{%- style -%}
  .ra-home-cta {
    padding: clamp(56px, 6vw, 88px) 0 clamp(48px, 5vw, 72px);
  }

  .ra-home-cta .ra-about-cta__button {
    margin-top: 28px;
  }
{%- endstyle -%}

<section class="ra-about ra-about-cta ra-home-cta">
  <div class="ra-about__shell">
    <div class="ra-about-cta__inner">
      <p class="ra-about__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      <h2 class="ra-about__section-heading">{{ section.settings.heading | escape }}</h2>
      <div class="ra-about__body ra-about-cta__body">{{ section.settings.body }}</div>

      {%- if section.settings.button_label != blank and section.settings.button_link != blank -%}
        <a class="ra-about-cta__button" href="{{ section.settings.button_link }}">
          {{ section.settings.button_label | escape }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Home call to action",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Represent America" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "You Represent America." },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body",
      "default": "<p>Watch what's happening. Read what's endured. Support what's still being built. This is Rep America.</p>"
    },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "About Rep America" },
    { "type": "url", "id": "button_link", "label": "Button link" }
  ],
  "presets": [
    { "name": "Home call to action" }
  ]
}
{% endschema %}
