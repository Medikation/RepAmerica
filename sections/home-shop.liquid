<section class="ra-section ra-home-shop" id="HomeShop-{{ section.id }}">
  <div class="ra-container-sm ra-text-center">
    {%- if section.settings.eyebrow != blank -%}
      <p class="ra-section-header__eyebrow">{{ section.settings.eyebrow | escape }}</p>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="ra-section-header__title">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}
    {%- if section.settings.badges != blank -%}
      <div class="ra-intro__text">{{ section.settings.badges }}</div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Home shop teaser",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "American Craftsmanship" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Products That Reflect Our Values" },
    {
      "type": "richtext",
      "id": "badges",
      "label": "Trust line",
      "default": "<p>Made in the USA · Built to Last · Limited Runs</p>"
    }
  ],
  "presets": [
    { "name": "Home shop teaser" }
  ]
}
{% endschema %}
