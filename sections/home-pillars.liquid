{%- style -%}
  #HomePillars-{{ section.id }} .ra-home-pillars__header {
    max-width: 640px;
    margin-left: auto;
    margin-right: auto;
  }
{%- endstyle -%}

<section class="ra-publication ra-publication__section" id="HomePillars-{{ section.id }}">
  <div class="ra-publication__section-inner">
    <div class="ra-section-header ra-text-center ra-home-pillars__header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="ra-section-header__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}
      <h2 class="ra-section-header__title">{{ section.settings.heading | escape }}</h2>
      {%- if section.settings.intro != blank -%}
        <div class="ra-section-header__text">{{ section.settings.intro }}</div>
      {%- endif -%}
    </div>

    <div class="ra-publication__pillars">
      {%- for block in section.blocks -%}
        <article class="ra-publication__pillar" {{ block.shopify_attributes }}>
          <span class="ra-publication__pillar-number">{{ block.settings.label | escape }}</span>
          <h3 class="ra-publication__pillar-title">{{ block.settings.heading | escape }}</h3>
          <div class="ra-publication__pillar-text">{{ block.settings.body }}</div>
          {%- if block.settings.link_label != blank and block.settings.link_url != blank -%}
            <p style="margin: 20px 0 0;">
              <a class="ra-text-link" href="{{ block.settings.link_url }}">{{ block.settings.link_label | escape }}</a>
            </p>
          {%- endif -%}
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Home pillars",
  "tag": "section",
  "max_blocks": 3,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "How Rep America Builds" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Three Ways to Represent America." },
    {
      "type": "richtext",
      "id": "intro",
      "label": "Intro",
      "default": "<p>Independent media, timeless ideas, and American craftsmanship — three pillars, one mission.</p>"
    }
  ],
  "blocks": [
    {
      "type": "pillar",
      "name": "Pillar",
      "settings": [
        { "type": "text", "id": "label", "label": "Number label", "default": "01" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Independent Media" },
        {
          "type": "richtext",
          "id": "body",
          "label": "Body",
          "default": "<p>Direct commentary and conversations on the issues shaping America — without the institutional filter.</p>"
        },
        { "type": "text", "id": "link_label", "label": "Link label", "default": "Watch Now" },
        { "type": "url", "id": "link_url", "label": "Link URL" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Home pillars",
      "blocks": [
        {
          "type": "pillar",
          "settings": {
            "label": "01",
            "heading": "Independent Media",
            "body": "<p>Direct commentary and conversations on the issues shaping America — without the institutional filter.</p>",
            "link_label": "Watch Now"
          }
        },
        {
          "type": "pillar",
          "settings": {
            "label": "02",
            "heading": "The Great Books Project",
            "body": "<p>A curated reading project on the ideas and books that built Western civilization.</p>",
            "link_label": "Explore the Project"
          }
        },
        {
          "type": "pillar",
          "settings": {
            "label": "03",
            "heading": "The Workshop",
            "body": "<p>American-made goods and everyday essentials, built by people who still build.</p>",
            "link_label": "Shop the Workshop"
          }
        }
      ]
    }
  ]
}
{% endschema %}
