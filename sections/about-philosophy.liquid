{{ 'rep-america-about.css' | asset_url | stylesheet_tag }}
<section class="ra-about ra-about-philosophy">
  <div class="ra-about__shell">
    <div class="ra-about-philosophy__intro">
      <div>
        <p class="ra-about__eyebrow">{{ section.settings.kicker | escape }}</p>
        <h2 class="ra-about__section-heading">{{ section.settings.heading | escape }}</h2>
      </div>
      <div class="ra-about__body">{{ section.settings.intro }}</div>
    </div>

    <div class="ra-about-philosophy__chain" aria-label="Rep America philosophy">
      {%- assign labels = 'Stronger Individuals|Stronger Families|Stronger Communities|Stronger America' | split: '|' -%}
      {%- for label in labels -%}
        <div class="ra-about-philosophy__item">
          <span class="ra-about-philosophy__number">0{{ forloop.index }}</span>
          <span class="ra-about-philosophy__label">{{ label }}</span>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name":"About philosophy",
  "tag":"section",
  "settings":[
    {"type":"text","id":"kicker","label":"Kicker","default":"Our Philosophy"},
    {"type":"text","id":"heading","label":"Heading","default":"Strength compounds."},
    {"type":"richtext","id":"intro","label":"Introduction","default":"<p>Lasting national strength begins with capable individuals. Strong individuals build strong families, strong families build resilient communities, and resilient communities build a stronger America.</p>"}
  ],
  "presets":[{"name":"About philosophy"}]
}
{% endschema %}
