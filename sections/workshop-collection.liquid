<section class="ra-section ra-workshop-collection" id="{{ section.settings.anchor | default: 'rep-collection' }}">
  <div class="ra-container-sm ra-text-center">
    {%- if section.settings.eyebrow != blank -%}
      <p class="ra-section-header__eyebrow">{{ section.settings.eyebrow | escape }}</p>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h2 class="ra-section-header__title">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}
    {%- if section.settings.text != blank -%}
      <div class="ra-intro__text">{{ section.settings.text }}</div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Workshop collection intro",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "anchor", "label": "Anchor ID", "default": "rep-collection" },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Made in the USA" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Rep Collection" },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Rep America products built for people who believe in American craftsmanship and wear their convictions proudly.</p>"
    }
  ],
  "presets": [
    { "name": "Workshop collection intro" }
  ]
}
{% endschema %}
