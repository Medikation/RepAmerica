<section class="ra-hero" id="WorkshopHero-{{ section.id }}">
  <div class="ra-container ra-hero__inner">
    <div>
      {%- if section.settings.eyebrow != blank -%}
        <p class="ra-hero__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h1 class="ra-hero__title">{{ section.settings.heading | escape }}</h1>
      {%- endif -%}

      {%- if section.settings.text != blank -%}
        <div class="ra-hero__text">{{ section.settings.text }}</div>
      {%- endif -%}

      <div class="ra-hero__actions">
        {%- if section.settings.button_label != blank and section.settings.button_link != blank -%}
          <a href="{{ section.settings.button_link }}" class="ra-button ra-button--primary">{{ section.settings.button_label | escape }}</a>
        {%- endif -%}
        {%- if section.settings.button_label_2 != blank and section.settings.button_link_2 != blank -%}
          <a href="{{ section.settings.button_link_2 }}" class="ra-button ra-button--secondary">{{ section.settings.button_label_2 | escape }}</a>
        {%- endif -%}
      </div>
    </div>

    <div class="ra-hero__visual">
      {%- if section.settings.image != blank -%}
        {{
          section.settings.image
          | image_url: width: 1600
          | image_tag:
            loading: 'eager',
            fetchpriority: 'high',
            widths: '600, 900, 1200, 1600',
            sizes: '(min-width: 990px) 46vw, 100vw',
            alt: section.settings.image.alt
        }}
      {%- else -%}
        <div class="ra-hero__visual-placeholder">Add a hero image</div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Workshop hero",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Craftsmanship • Essentials • Great Books"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Workshop"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Subtext",
      "default": "<p>American-made goods, everyday essentials, and the ideas behind them.</p>"
    },
    { "type": "header", "content": "Primary button" },
    { "type": "text", "id": "button_label", "label": "Label", "default": "Shop Rep Collection" },
    { "type": "url", "id": "button_link", "label": "Link" },
    { "type": "header", "content": "Secondary button" },
    { "type": "text", "id": "button_label_2", "label": "Label", "default": "Browse The Essentials" },
    { "type": "url", "id": "button_link_2", "label": "Link" },
    { "type": "header", "content": "Visual" },
    { "type": "image_picker", "id": "image", "label": "Hero image" }
  ],
  "presets": [
    { "name": "Workshop hero" }
  ]
}
{% endschema %}
