{%- comment -%}
  Home hero — editorial. Two columns on a warm off-white field.

  Left: the pitch (eyebrow / H1 / mission), and directly beneath it the newest Watch video as a
  real, playable panel. Right: Medi, matted with a transparent background, standing the full
  height of the section and dissolving into the page at the bottom.

  The section has no bottom edge by design: its background resolves to pure white, the same
  colour as the page below it. A hard boundary under a portrait that fades out would cancel the
  fade — the two ideas have to agree.

  The video is a FACADE, not an iframe: a YouTube thumbnail + play button, which swaps itself
  for the real player on click. An embedded iframe would pull ~1MB of YouTube JS into every
  homepage load, on the page most likely to be a visitor's first.
{%- endcomment -%}

{%- liquid
  assign eyebrow = section.settings.eyebrow | strip
  assign heading = section.settings.heading | strip
  assign text = section.settings.text
  assign portrait = section.settings.image

  assign video_blog = blogs[section.settings.video_blog] | default: blogs['watch']
  assign latest = video_blog.articles.first
-%}

{%- if latest != blank -%}
  {%- assign latest_url = latest.metafields.custom.youtube_url.value | default: latest.metafields.custom.youtube_url -%}
  {%- capture latest_id -%}{%- render 'youtube-id', youtube_url: latest_url -%}{%- endcapture -%}
  {%- assign latest_id = latest_id | strip -%}
  {%- assign latest_duration = latest.metafields.custom.duration.value | default: latest.metafields.custom.duration -%}
{%- endif -%}

<section
  id="HomeHero-{{ section.id }}"
  class="ra-home-hero"
  aria-labelledby="HomeHeroHeading-{{ section.id }}"
>
  <div class="ra-home-hero__inner">
    <div class="ra-home-hero__col">
      <div class="ra-home-hero__copy">
        {%- if eyebrow != blank -%}
          <p class="ra-home-hero__kicker">{{ eyebrow | escape }}</p>
        {%- endif -%}

        {%- comment -%}
          Headline and tagline are one block so the portrait can sit alongside them in a single
          grid cell on mobile — type on the left, him on the right, overlapping in one column.
        {%- endcomment -%}
        <div class="ra-home-hero__headline-block">
          {%- if heading != blank -%}
            <h1 id="HomeHeroHeading-{{ section.id }}" class="ra-home-hero__heading">
              <span class="ra-home-hero__heading-a">{{ heading | escape }}</span>
            </h1>
          {%- endif -%}

          {%- if section.settings.heading_2 != blank -%}
            <div class="ra-home-hero__tagline">
              <span class="ra-home-hero__rule"></span>
              <p class="ra-home-hero__tagline-text">{{ section.settings.heading_2 | escape }}</p>
            </div>
          {%- endif -%}
        </div>

        {%- comment -%}
          The portrait lives inside the copy block so that on mobile it can sit in the same grid
          row as the headline. On desktop it is absolutely positioned, which resolves against
          `.ra-home-hero__inner` (the nearest positioned ancestor) regardless of where it sits in
          the markup — so nothing about the desktop composition changes.
        {%- endcomment -%}
        {%- if portrait != blank -%}
          <div class="ra-home-hero__portrait">
            {{
              portrait
              | image_url: width: 1400
              | image_tag:
                class: 'ra-home-hero__portrait-img',
                widths: '600, 800, 1000, 1400',
                sizes: '(max-width: 989px) 46vw, 42vw',
                loading: 'eager',
                fetchpriority: 'high',
                alt: portrait.alt
            }}
          </div>
        {%- endif -%}

        {%- if text != blank -%}
          <div class="ra-home-hero__lede">{{ text }}</div>
        {%- endif -%}

        {%- if section.settings.button_label != blank and section.settings.button_link != blank or section.settings.button_label_2 != blank and section.settings.button_link_2 != blank -%}
          <div class="ra-home-hero__actions">
            {%- if section.settings.button_label != blank and section.settings.button_link != blank -%}
              <a href="{{ section.settings.button_link }}" class="ra-button ra-button--primary">{{ section.settings.button_label | escape }}</a>
            {%- endif -%}
            {%- if section.settings.button_label_2 != blank and section.settings.button_link_2 != blank -%}
              <a href="{{ section.settings.button_link_2 }}" class="ra-button ra-button--secondary">{{ section.settings.button_label_2 | escape }}</a>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>

      {%- if latest != blank and latest_id != blank -%}
        <div class="ra-home-hero__video">
          {%- if section.settings.video_label != blank -%}
            <p class="ra-home-hero__video-label">
              <span class="ra-home-hero__live-dot" aria-hidden="true"></span>
              {{ section.settings.video_label | escape }}
            </p>
          {%- endif -%}

          <div class="ra-home-hero__player" data-ra-video="{{ latest_id }}">
            <button
              type="button"
              class="ra-home-hero__facade"
              aria-label="Play {{ latest.title | escape }}"
            >
              <img
                src="https://img.youtube.com/vi/{{ latest_id }}/maxresdefault.jpg"
                alt=""
                loading="eager"
                onerror="this.src='https://img.youtube.com/vi/{{ latest_id }}/hqdefault.jpg'"
              >
              <span class="ra-home-hero__play" aria-hidden="true">
                <svg viewBox="0 0 24 24" width="26" height="26" focusable="false"><path d="M8 5.5v13l11-6.5z" fill="currentColor"/></svg>
              </span>
              {%- if latest_duration != blank -%}
                <span class="ra-home-hero__duration">{{ latest_duration }}</span>
              {%- endif -%}
            </button>
          </div>

          <a class="ra-home-hero__video-title" href="{{ latest.url }}">{{ latest.title }}</a>
        </div>
      {%- endif -%}
    </div>

  </div>
</section>

<style>
  #HomeHero-{{ section.id }} {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    /* Three layers, in order:
       1. A barely-there warm radial behind the subject — museum lighting, not a spotlight.
          It exists so he sits in a room rather than floating on a flat field.
       2. A warm off-white field (#faf8f4 — warm, not beige, not grey).
       3. That field resolving to pure #fff at the very bottom, so the hero has NO edge: the
          page it hands off to is white, and the two are the same colour where they meet. */
    background:
      radial-gradient(ellipse 58% 78% at 72% 55%, rgba(255, 246, 232, 0.85) 0%, rgba(255, 246, 232, 0) 70%),
      linear-gradient(
        180deg,
        #ffffff 0%,
        #fbf9f6 9%,
        #faf8f4 22%,
        #faf8f4 58%,
        #fdfcfa 82%,
        #ffffff 100%
      );
    color: #14140f;
  }

  /* The left column sets the section's height; the portrait is absolutely positioned and
     matched to it, so he is always exactly as tall as the copy + player beside him. */
  #HomeHero-{{ section.id }} .ra-home-hero__inner {
    position: relative;
    width: min(calc(100% - 48px), 1280px);
    margin: 0 auto;
    padding-top: 36px;
  }

  #HomeHero-{{ section.id }} .ra-home-hero__col {
    width: min(54%, 680px);
    padding-bottom: 36px;
  }

  #HomeHero-{{ section.id }} .ra-home-hero__kicker {
    margin: 0 0 14px;
    color: rgba(20, 20, 15, 0.55);
    font-size: 11px;
    line-height: 1;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  #HomeHero-{{ section.id }} .ra-home-hero__heading {
    margin: 0;
    color: #14140f;
    font-family: var(--font-heading-family, Georgia, serif);
    font-size: clamp(34px, 3.4vw, 54px);
    font-weight: var(--font-heading-weight, 700);
    line-height: 1.02;
    letter-spacing: -0.03em;
    text-wrap: balance;
  }

  /* The tagline — red rule + line — reads the same at every size; only the scale changes. */
  #HomeHero-{{ section.id }} .ra-home-hero__tagline {
    margin-top: 26px;
  }

  #HomeHero-{{ section.id }} .ra-home-hero__rule {
    display: block;
    width: 84px;
    height: 2px;
    margin: 0 0 16px;
    background: #c62436;
  }

  #HomeHero-{{ section.id }} .ra-home-hero__tagline-text {
    margin: 0;
    color: #14140f;
    font-family: var(--font-heading-family, Georgia, serif);
    font-size: clamp(22px, 1.9vw, 30px);
    font-weight: var(--font-heading-weight, 700);
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  #HomeHero-{{ section.id }} .ra-home-hero__lede {
    max-width: 46em;
    margin-top: 14px;
    color: rgba(20, 20, 15, 0.74);
  }

  #HomeHero-{{ section.id }} .ra-home-hero__lede p {
    margin: 0;
    color: inherit;
    font-size: 17px;
    line-height: 1.5;
  }

  #HomeHero-{{ section.id }} .ra-home-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 22px;
  }

  #HomeHero-{{ section.id }} .ra-home-hero__actions .ra-button--secondary {
    color: #111;
    border-color: rgba(17, 17, 17, 0.35);
  }

  #HomeHero-{{ section.id }} .ra-home-hero__actions .ra-button--secondary:hover {
    background: #111;
    color: #fff;
    border-color: #111;
  }

  /* --- The player ---
     Capped below the column width: the player's 16:9 height is what drives the section's
     overall height, so a narrower player is a shorter hero. */
  #HomeHero-{{ section.id }} .ra-home-hero__video {
    max-width: 560px;
    /* Room to finish the mission statement before the eye drops into the video. */
    margin-top: 44px;
  }

  /* The hero hands off to the next section with no seam: its own background has already
     resolved to white, and the gap is pulled in so the two read as one canvas. */
  #shopify-section-{{ section.id }} + * {
    margin-top: -44px;
  }

  #HomeHero-{{ section.id }} .ra-home-hero__video-label {
    display: flex;
    align-items: center;
    gap: 8px;
    margin: 0 0 10px;
    color: rgba(20, 20, 15, 0.62);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  #HomeHero-{{ section.id }} .ra-home-hero__live-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #c62436;
  }

  #HomeHero-{{ section.id }} .ra-home-hero__player {
    position: relative;
    aspect-ratio: 16 / 9;
    border-radius: 10px;
    overflow: hidden;
    background: #000;
    box-shadow: 0 18px 44px rgba(20, 18, 14, 0.16);
  }

  #HomeHero-{{ section.id }} .ra-home-hero__facade {
    display: block;
    width: 100%;
    height: 100%;
    padding: 0;
    border: 0;
    background: none;
    cursor: pointer;
  }

  #HomeHero-{{ section.id }} .ra-home-hero__facade img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease, opacity 0.3s ease;
  }

  #HomeHero-{{ section.id }} .ra-home-hero__facade:hover img {
    transform: scale(1.02);
    opacity: 0.9;
  }

  #HomeHero-{{ section.id }} .ra-home-hero__play {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    display: grid;
    place-items: center;
    width: 66px;
    height: 66px;
    border-radius: 50%;
    background: rgba(17, 17, 17, 0.62);
    border: 1px solid rgba(255, 255, 255, 0.75);
    color: #fff;
    transition: background 0.2s ease, transform 0.2s ease;
  }

  #HomeHero-{{ section.id }} .ra-home-hero__facade:hover .ra-home-hero__play {
    background: #c62436;
    border-color: #c62436;
    transform: translate(-50%, -50%) scale(1.06);
  }

  #HomeHero-{{ section.id }} .ra-home-hero__duration {
    position: absolute;
    right: 10px;
    bottom: 10px;
    padding: 3px 8px;
    border-radius: 4px;
    background: rgba(0, 0, 0, 0.78);
    color: #fff;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.02em;
  }

  #HomeHero-{{ section.id }} .ra-home-hero__player iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  #HomeHero-{{ section.id }} .ra-home-hero__video-title {
    display: block;
    margin-top: 12px;
    color: #14140f;
    font-family: var(--font-heading-family, Georgia, serif);
    font-size: 19px;
    line-height: 1.3;
    text-decoration: none;
  }

  #HomeHero-{{ section.id }} .ra-home-hero__video-title:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* --- The cutout ---
     Absolute, floor-to-ceiling of the section, anchored to the copy column's right edge. The
     image is wider than the space left for it, so it bleeds off the right of the frame rather
     than being shrunk to fit — that's what lets him stand at full height. */
  /* Sits close enough that his shoulder nearly meets the player. */
  #HomeHero-{{ section.id }} .ra-home-hero__portrait {
    position: absolute;
    top: 0;
    bottom: 0;
    left: 43%;
    right: 0;
    pointer-events: none;
  }

  /* 108%, anchored to the TOP — not the bottom. The file carries transparent headroom above the
     hat and a dissolve that finishes at ~92% of its own height, which is exactly where the
     section's bottom edge lands at this scale — so only empty pixels are ever clipped.
     Anchoring to the bottom instead would drive the hat up into the top fade; scaling up without
     re-timing the dissolve would either cut him mid-shirt (a hard line again) or eat his
     shoulders. The image scale and the fade's timing are one decision, not two. */
  #HomeHero-{{ section.id }} .ra-home-hero__portrait-img {
    display: block;
    height: 108%;
    width: auto;
    max-width: none;
    object-fit: contain;
    object-position: top left;
    /* No drop-shadow. A shadow under a figure that is *dissolving* into the page announces the
       cutout — the exact thing we're hiding. The warm radial behind him does the grounding. */
  }

  @media screen and (max-width: 989px) {
    /* Mobile is its own composition: the three words on the left, the portrait beside them on
       the right, then a red rule and "America in Real Time." running the full width beneath
       both — and the player directly under that. The eyebrow and the mission statement are
       deliberately not shown; on a phone they push the video below the fold for no gain. */
    #HomeHero-{{ section.id }} .ra-home-hero__inner {
      display: block;
      width: 100%;
      padding-top: 0;
    }

    #HomeHero-{{ section.id }} .ra-home-hero__col {
      width: 100%;
      padding: 14px 20px 28px;
    }

    /* Headline and portrait share ONE grid cell rather than sitting in two columns. In two
       columns he could only ever be as wide as the column left over from the type; stacked in
       the same cell he can run to 88% of the width and bleed off the right edge, with the
       headline held to the left over the transparent part of his shoulder. The cell's height is
       set by him, and the headline is bottom-aligned inside it. */
    #HomeHero-{{ section.id }} .ra-home-hero__copy {
      display: grid;
      grid-template-columns: minmax(0, 1fr);
    }

    #HomeHero-{{ section.id }} .ra-home-hero__headline-block,
    #HomeHero-{{ section.id }} .ra-home-hero__portrait {
      grid-area: 1 / 1;
    }

    /* Type starts at the top of the cell, level with the crown of the hat; he runs down past it
       on the right and dissolves into the page below. */
    #HomeHero-{{ section.id }} .ra-home-hero__headline-block {
      position: relative;
      z-index: 1;
      align-self: start;
      /* Dropped down the cell rather than sitting hard against the top. */
      margin-top: 8vw;
      /* Narrow enough that the tagline can't run into his shoulder — his silhouette starts
         around the halfway mark once he's bled off the right edge. */
      max-width: 50%;
    }

    #HomeHero-{{ section.id }} .ra-home-hero__portrait {
      align-self: end;
    }

    #HomeHero-{{ section.id }} .ra-home-hero__kicker,
    #HomeHero-{{ section.id }} .ra-home-hero__lede,
    #HomeHero-{{ section.id }} .ra-home-hero__actions {
      display: none;
    }

    #HomeHero-{{ section.id }} .ra-home-hero__heading {
      max-width: none;
      padding: 0;
      font-size: clamp(30px, 8.6vw, 42px);
      line-height: 1.22;
      text-wrap: initial;
    }

    /* One word per line — "Politics." / "Culture." / "Commentary." — without hard-coding line
       breaks into the setting. A word-space wider than the screen forces a break at every space,
       so the copy stays plain text and stays editable in the Theme Editor. */
    #HomeHero-{{ section.id }} .ra-home-hero__heading-a {
      display: block;
      word-spacing: 100vw;
    }

    /* Only the first half of the headline on mobile — the rest is the tagline below. */
    #HomeHero-{{ section.id }} .ra-home-hero__heading-b {
      display: none;
    }

    /* He runs off the right edge of the phone. The margin has to be a big NEGATIVE viewport
       value, not a few pixels: the image is already ~full-width, so a -20px bleed moved him
       almost nothing. This pulls his right side well past the screen so he's cropped mid-torso,
       and his face lands in the right half — with the type clear on the left. */
    #HomeHero-{{ section.id }} .ra-home-hero__portrait {
      position: static;
      z-index: 0;
      display: flex;
      justify-content: flex-end;
      margin-right: -58vw;
    }

    #HomeHero-{{ section.id }} .ra-home-hero__portrait-img {
      height: auto;
      width: 108%;
      max-width: none;
      /* The bottom ~20% of the file is the dissolve — mostly transparent pixels that still take
         up layout space, which is what was leaving a hole between him and the player. Pulling the
         image's bottom margin up reclaims it without touching the fade itself. */
      margin-bottom: -15vw;
    }

    #HomeHero-{{ section.id }} .ra-home-hero__tagline {
      margin-top: 22px;
    }

    #HomeHero-{{ section.id }} .ra-home-hero__rule {
      width: 76px;
      margin-bottom: 14px;
    }

    #HomeHero-{{ section.id }} .ra-home-hero__tagline-text {
      font-size: clamp(22px, 6.4vw, 30px);
      line-height: 1.14;
    }

    #HomeHero-{{ section.id }} .ra-home-hero__video {
      max-width: none;
      margin-top: 22px;
    }
  }
</style>

<script>
  (function () {
    var root = document.getElementById('HomeHero-{{ section.id }}');
    if (!root) return;
    var player = root.querySelector('[data-ra-video]');
    if (!player) return;

    player.addEventListener('click', function () {
      var id = player.getAttribute('data-ra-video');
      if (!id || player.querySelector('iframe')) return;

      var frame = document.createElement('iframe');
      frame.src = 'https://www.youtube-nocookie.com/embed/' + id + '?autoplay=1&rel=0&modestbranding=1';
      frame.title = 'YouTube video player';
      frame.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share';
      frame.allowFullscreen = true;
      player.innerHTML = '';
      player.appendChild(frame);
    });
  })();
</script>

{% schema %}
{
  "name": "Home hero",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Independent Media • Timeless Ideas • American Craftsmanship"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Politics. Culture. Commentary.",
      "info": "On desktop this runs into the second line below as one headline. On mobile it sits beside the portrait on its own."
    },
    {
      "type": "text",
      "id": "heading_2",
      "label": "Heading — second half",
      "default": "America in Real Time.",
      "info": "On mobile this drops below the portrait, under a red rule, at a smaller size."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Subtext",
      "default": "<p>Independent political commentary, timeless ideas, and American-made craftsmanship — for people who still build.</p>"
    },
    { "type": "header", "content": "Primary button" },
    { "type": "text", "id": "button_label", "label": "Label", "default": "Watch Rep America Live" },
    { "type": "url", "id": "button_link", "label": "Link" },
    { "type": "header", "content": "Secondary button" },
    { "type": "text", "id": "button_label_2", "label": "Label", "default": "Explore Our Mission" },
    { "type": "url", "id": "button_link_2", "label": "Link" },
    { "type": "header", "content": "Latest video" },
    {
      "type": "blog",
      "id": "video_blog",
      "label": "Blog to pull the newest video from",
      "info": "Defaults to the Watch blog. The most recently published article is used."
    },
    { "type": "text", "id": "video_label", "label": "Label above the player", "default": "Latest Episode" },
    { "type": "header", "content": "Portrait" },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Cutout image",
      "info": "A PNG with a transparent background. It bleeds off the bottom edge of the section."
    }
  ],
  "presets": [
    { "name": "Home hero" }
  ]
}
{% endschema %}
