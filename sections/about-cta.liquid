{{ 'rep-america-about.css' | asset_url | stylesheet_tag }}
<section class="ra-about ra-about-cta">
  <div class="ra-about__shell">
    <div class="ra-about-cta__inner">
      <p class="ra-about__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      <h2 class="ra-about__section-heading">{{ section.settings.heading | escape }}</h2>
      <div class="ra-about__body ra-about-cta__body">{{ section.settings.body }}</div>

      {%- if section.settings.button_label != blank and section.settings.button_link != blank -%}
        <a class="ra-about-cta__button" href="{{ section.settings.button_link }}">
          {{ section.settings.button_label | escape }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name":"About call to action",
  "tag":"section",
  "settings":[
    {"type":"text","id":"eyebrow","label":"Eyebrow","default":"Join the Mission"},
    {"type":"text","id":"heading","label":"Heading","default":"Build something stronger."},
    {"type":"richtext","id":"body","label":"Body","default":"<p>Watch the work. Read the ideas. Support the builders. Rep America is for people who believe strength is built through action.</p>"},
    {"type":"text","id":"button_label","label":"Button label","default":"Explore Rep America"},
    {"type":"url","id":"button_link","label":"Button link"}
  ],
  "presets":[{"name":"About call to action"}]
}
{% endschema %}
