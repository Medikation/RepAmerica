{%- assign home_blog = section.settings.blog | default: blogs['watch'] -%}

<section class="ra-section ra-home-latest" id="HomeLatest-{{ section.id }}">
  <div class="ra-container">
    <div class="ra-section-header ra-section-header--row">
      <div>
        {%- if section.settings.eyebrow != blank -%}
          <p class="ra-section-header__eyebrow">{{ section.settings.eyebrow | escape }}</p>
        {%- endif -%}
        <h2 class="ra-section-header__title">{{ section.settings.heading | escape }}</h2>
        {%- if section.settings.text != blank -%}
          <div class="ra-section-header__text">{{ section.settings.text }}</div>
        {%- endif -%}
      </div>
      {%- if section.settings.button_label != blank and section.settings.button_link != blank -%}
        <div class="ra-section-header__actions">
          <a href="{{ section.settings.button_link }}" class="ra-text-link">{{ section.settings.button_label | escape }}</a>
        </div>
      {%- endif -%}
    </div>

    <div class="ra-grid-3">
      {%- comment -%}
        `offset` exists so this section can pick up where the hero leaves off: the hero plays the
        newest video, so an offset of 1 shows the next three in line rather than repeating it.
      {%- endcomment -%}
      {%- for article in home_blog.articles offset: section.settings.offset limit: section.settings.limit -%}
        {%- assign category = article.metafields.custom.category.value | default: article.metafields.custom.category | default: 'Commentary' -%}
        {%- assign youtube_url = article.metafields.custom.youtube_url.value | default: article.metafields.custom.youtube_url -%}
        {%- capture video_id -%}{%- render 'youtube-id', youtube_url: youtube_url -%}{%- endcapture -%}
        {%- assign video_id = video_id | strip -%}
        {%- assign duration = article.metafields.custom.duration.value | default: article.metafields.custom.duration -%}

        <article class="ra-video-card">
          <a href="{{ article.url }}" class="ra-video-card__link" aria-label="Watch {{ article.title | escape }}">
            <div class="ra-video-card__thumb">
              {%- if video_id != blank -%}
                <img
                  src="https://img.youtube.com/vi/{{ video_id }}/hqdefault.jpg"
                  alt="{{ article.title | escape }}"
                  loading="lazy"
                >
              {%- elsif article.image -%}
                <img
                  src="{{ article.image | image_url: width: 900 }}"
                  alt="{{ article.title | escape }}"
                  loading="lazy"
                >
              {%- endif -%}
              {%- if duration != blank -%}
                <span class="ra-video-card__duration">{{ duration }}</span>
              {%- endif -%}
            </div>

            <div class="ra-video-card__body">
              <div class="ra-video-card__category">{{ category }}</div>
              <h3 class="ra-video-card__title">{{ article.title }}</h3>
              <div class="ra-video-card__meta">{{ article.published_at | date: "%b %-d, %Y" }}</div>
            </div>
          </a>
        </article>
      {%- else -%}
        <p class="ra-empty">No videos published yet — check back soon.</p>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Home latest videos",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Latest Broadcast" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "New From Rep America" },
    { "type": "richtext", "id": "text", "label": "Text (optional)" },
    {
      "type": "blog",
      "id": "blog",
      "label": "Blog to pull videos from",
      "info": "Defaults to the Watch blog."
    },
    {
      "type": "range",
      "id": "limit",
      "label": "Videos to show",
      "min": 3,
      "max": 12,
      "step": 3,
      "default": 3
    },
    {
      "type": "range",
      "id": "offset",
      "label": "Skip the newest",
      "min": 0,
      "max": 6,
      "step": 1,
      "default": 0,
      "info": "Set to 1 when the hero is already playing the newest video, so this grid shows the next ones in line instead of repeating it."
    },
    { "type": "text", "id": "button_label", "label": "Link label", "default": "View All Videos" },
    { "type": "url", "id": "button_link", "label": "Link URL" }
  ],
  "presets": [
    { "name": "Home latest videos" }
  ]
}
{% endschema %}
