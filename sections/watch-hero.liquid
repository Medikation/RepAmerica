{%- assign watch_blog = section.settings.blog | default: blogs['watch'] -%}
{%- assign featured_article = section.settings.featured_article -%}
{%- if featured_article == blank -%}
  {%- assign featured_article = watch_blog.articles.first -%}
{%- endif -%}

<section class="ra-section ra-watch-hero" id="WatchHero-{{ section.id }}">
  <div class="ra-container">
    <div class="ra-section-header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="ra-section-header__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}
      <h1 class="ra-section-header__title">{{ section.settings.heading | escape }}</h1>
      {%- if section.settings.text != blank -%}
        <div class="ra-section-header__text">{{ section.settings.text }}</div>
      {%- endif -%}
    </div>

    {%- if featured_article != blank -%}
      {%- assign youtube_url = featured_article.metafields.custom.youtube_url.value | default: featured_article.metafields.custom.youtube_url -%}
      {%- capture video_id -%}{%- render 'youtube-id', youtube_url: youtube_url -%}{%- endcapture -%}
      {%- assign video_id = video_id | strip -%}
      {%- assign category = featured_article.metafields.custom.category.value | default: featured_article.metafields.custom.category | default: 'Commentary' -%}
      {%- assign excerpt = featured_article.excerpt | default: featured_article.content | strip_html | truncatewords: 30 -%}
      {%- assign duration = featured_article.metafields.custom.duration.value | default: featured_article.metafields.custom.duration -%}

      <div class="ra-featured-video">
        <a
          href="{{ featured_article.url }}"
          class="ra-featured-video__link"
          aria-label="Watch {{ featured_article.title | escape }}"
        >
          <div class="ra-featured-video__thumb">
            {%- if video_id != blank -%}
              <img
                src="https://img.youtube.com/vi/{{ video_id }}/maxresdefault.jpg"
                alt="{{ featured_article.title | escape }}"
                loading="eager"
              >
            {%- elsif featured_article.image -%}
              <img
                src="{{ featured_article.image | image_url: width: 1200 }}"
                alt="{{ featured_article.title | escape }}"
                loading="eager"
              >
            {%- endif -%}
            <span class="ra-featured-video__play" aria-hidden="true">▶</span>
            {%- if duration != blank -%}
              <span class="ra-featured-video__duration">{{ duration }}</span>
            {%- endif -%}
          </div>
        </a>

        <div class="ra-featured-video__body">
          {%- if section.settings.featured_label != blank -%}
            <p class="ra-featured-video__eyebrow">{{ section.settings.featured_label | escape }}</p>
          {%- endif -%}
          <a href="{{ featured_article.url }}">
            <h2 class="ra-featured-video__title">{{ featured_article.title }}</h2>
          </a>
          {%- if excerpt != blank -%}
            <p class="ra-featured-video__excerpt">{{ excerpt }}</p>
          {%- endif -%}
          <p class="ra-featured-video__meta">{{ category }} · {{ featured_article.published_at | date: "%b %-d, %Y" }}</p>
          <a href="{{ featured_article.url }}" class="ra-button ra-button--primary">Watch Now</a>
        </div>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Watch hero",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow / kicker",
      "default": "Independent Media"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Watch"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Intro text",
      "default": "<p>Independent media, timeless ideas, and the people building a stronger America — on camera.</p>"
    },
    {
      "type": "header",
      "content": "Featured video"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Blog to pull the latest video from",
      "info": "Used as a fallback whenever no specific video is pinned below."
    },
    {
      "type": "article",
      "id": "featured_article",
      "label": "Pin a specific video (optional)",
      "info": "Leave blank to automatically feature the latest video from the blog above."
    },
    {
      "type": "text",
      "id": "featured_label",
      "label": "Featured video label",
      "default": "Latest Episode"
    }
  ],
  "presets": [
    {
      "name": "Watch hero"
    }
  ]
}
{% endschema %}
