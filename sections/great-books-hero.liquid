{%- liquid
  assign eyebrow = section.settings.eyebrow | strip
  assign heading = section.settings.heading | strip
  assign text = section.settings.text
  assign image = section.settings.image
  assign mobile_image = section.settings.mobile_image
-%}

<section
  id="GreatBooksHero-{{ section.id }}"
  class="ra-gb-hero-cinematic"
  aria-labelledby="GreatBooksHeroHeading-{{ section.id }}"
>
  <div class="ra-gb-hero-cinematic__media">
    {%- if image != blank -%}
      <picture>
        {%- if mobile_image != blank -%}
          <source
            media="(max-width: 989px)"
            srcset="{{ mobile_image | image_url: width: 750 }} 750w, {{ mobile_image | image_url: width: 1100 }} 1100w, {{ mobile_image | image_url: width: 1500 }} 1500w"
            sizes="100vw"
          >
        {%- endif -%}
        {{
          image
          | image_url: width: 3200
          | image_tag:
            class: 'ra-gb-hero-cinematic__image',
            loading: 'eager',
            fetchpriority: 'high',
            widths: '750, 1100, 1500, 2000, 2600, 3200',
            sizes: '100vw',
            alt: image.alt
        }}
      </picture>
    {%- else -%}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'ra-gb-hero-cinematic__placeholder' }}
    {%- endif -%}

    <div class="ra-gb-hero-cinematic__overlay" aria-hidden="true"></div>

    <div class="ra-gb-hero-cinematic__shell">
      <div class="ra-gb-hero-cinematic__content">
        {%- if eyebrow != blank -%}
          <p class="ra-gb-hero-cinematic__kicker">{{ eyebrow | escape }}</p>
        {%- endif -%}

        {%- if heading != blank -%}
          <h1
            id="GreatBooksHeroHeading-{{ section.id }}"
            class="ra-gb-hero-cinematic__heading"
          >
            {{ heading | escape }}
          </h1>
        {%- endif -%}

        {%- if text != blank -%}
          <div class="ra-gb-hero-cinematic__lede">
            {{ text }}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

<style>
  #GreatBooksHero-{{ section.id }} {
    --ra-overlay-strength: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    --ra-desktop-height: {{ section.settings.desktop_height }}px;
    --ra-desktop-focus-x: {{ section.settings.desktop_focus_x }}%;
    --ra-desktop-focus-y: {{ section.settings.desktop_focus_y }}%;
    --ra-mobile-focus-x: {{ section.settings.mobile_focus_x }}%;
    --ra-mobile-focus-y: {{ section.settings.mobile_focus_y }}%;
  }

  #GreatBooksHero-{{ section.id }}.ra-gb-hero-cinematic {
    position: relative;
    width: 100%;
    overflow: hidden;
    background: #111111;
    color: #ffffff;
  }

  #GreatBooksHero-{{ section.id }} .ra-gb-hero-cinematic__media {
    position: relative;
    min-height: var(--ra-desktop-height);
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }

  #GreatBooksHero-{{ section.id }} .ra-gb-hero-cinematic__image,
  #GreatBooksHero-{{ section.id }} .ra-gb-hero-cinematic__placeholder {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: var(--ra-desktop-focus-x) var(--ra-desktop-focus-y);
  }

  #GreatBooksHero-{{ section.id }} .ra-gb-hero-cinematic__overlay {
    display: block;
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background:
      linear-gradient(
        0deg,
        rgba(0, 0, 0, calc(var(--ra-overlay-strength) * 1.1)) 0%,
        rgba(0, 0, 0, calc(var(--ra-overlay-strength) * 0.85)) 30%,
        rgba(0, 0, 0, calc(var(--ra-overlay-strength) * 0.35)) 55%,
        rgba(0, 0, 0, 0.04) 80%,
        rgba(0, 0, 0, 0) 100%
      );
  }

  #GreatBooksHero-{{ section.id }} .ra-gb-hero-cinematic__shell {
    position: relative;
    z-index: 2;
    width: min(calc(100% - 48px), 1280px);
    margin: 0 auto;
  }

  #GreatBooksHero-{{ section.id }} .ra-gb-hero-cinematic__content {
    width: min(58%, 760px);
    padding: 0 0 56px;
  }

  #GreatBooksHero-{{ section.id }} .ra-gb-hero-cinematic__kicker {
    margin: 0 0 18px;
    color: rgba(255, 255, 255, 0.72);
    font-size: 11px;
    line-height: 1;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  #GreatBooksHero-{{ section.id }} .ra-gb-hero-cinematic__heading {
    max-width: 100%;
    margin: 0;
    color: #ffffff;
    font-family: var(--font-heading-family, Georgia, serif);
    font-size: clamp(40px, 4.4vw, 68px);
    font-style: var(--font-heading-style, normal);
    font-weight: var(--font-heading-weight, 700);
    line-height: 1;
    letter-spacing: -0.03em;
    text-wrap: balance;
  }

  #GreatBooksHero-{{ section.id }} .ra-gb-hero-cinematic__lede {
    max-width: 560px;
    margin-top: 20px;
    color: rgba(255, 255, 255, 0.9);
  }

  #GreatBooksHero-{{ section.id }} .ra-gb-hero-cinematic__lede p {
    margin: 0;
    color: inherit;
    font-size: clamp(18px, 1.45vw, 21px);
    line-height: 1.52;
  }

  @media screen and (max-width: 989px) {
    /* Mobile: image stacked full-width above the text (not overlaid), text
       block below on the section's solid dark background — matches About's
       hero pattern. */

    #GreatBooksHero-{{ section.id }} .ra-gb-hero-cinematic__media {
      display: block;
      position: static;
      min-height: 0;
    }

    #GreatBooksHero-{{ section.id }} .ra-gb-hero-cinematic__image,
    #GreatBooksHero-{{ section.id }} .ra-gb-hero-cinematic__placeholder {
      position: relative;
      inset: auto;
      width: 100%;
      height: auto;
      aspect-ratio: 4 / 5;
      object-position: var(--ra-mobile-focus-x) var(--ra-mobile-focus-y);
    }

    #GreatBooksHero-{{ section.id }} .ra-gb-hero-cinematic__overlay {
      display: none;
    }

    #GreatBooksHero-{{ section.id }} .ra-gb-hero-cinematic__shell {
      position: static;
      z-index: auto;
      width: 100%;
      margin: 0;
    }

    #GreatBooksHero-{{ section.id }} .ra-gb-hero-cinematic__content {
      width: 100%;
      max-width: none;
      padding: 32px 24px 40px;
    }

    #GreatBooksHero-{{ section.id }} .ra-gb-hero-cinematic__heading {
      max-width: none;
      font-size: clamp(34px, 9vw, 52px);
      line-height: 1.02;
    }

    #GreatBooksHero-{{ section.id }} .ra-gb-hero-cinematic__lede {
      max-width: none;
      margin-top: 18px;
    }

    #GreatBooksHero-{{ section.id }} .ra-gb-hero-cinematic__lede p {
      font-size: 16px;
      line-height: 1.48;
    }
  }

  @media screen and (max-width: 540px) {
    #GreatBooksHero-{{ section.id }} .ra-gb-hero-cinematic__content {
      padding-bottom: 24px;
    }

    #GreatBooksHero-{{ section.id }} .ra-gb-hero-cinematic__heading {
      font-size: clamp(36px, 10vw, 52px);
    }

    #GreatBooksHero-{{ section.id }} .ra-gb-hero-cinematic__kicker {
      font-size: 10px;
      letter-spacing: 0.17em;
    }
  }
</style>

{% schema %}
{
  "name": "Great Books hero",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow / kicker",
      "default": "Ideas • History • Civilization"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Great Books Project"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Intro text (optional)"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile hero image (optional)",
      "info": "If set, used on screens 989px and narrower instead of the main image above. On mobile the image is stacked full-width above the text (not overlaid), roughly 4:5 portrait — no need to leave clear space for text in the crop. Leave blank to reuse the main image on mobile."
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay strength",
      "min": 20,
      "max": 85,
      "step": 5,
      "unit": "%",
      "default": 70
    },
    {
      "type": "range",
      "id": "desktop_height",
      "label": "Desktop height",
      "min": 400,
      "max": 900,
      "step": 20,
      "unit": "px",
      "default": 480
    },
    { "type": "header", "content": "Desktop image position" },
    {
      "type": "range",
      "id": "desktop_focus_x",
      "label": "Horizontal position",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 50
    },
    {
      "type": "range",
      "id": "desktop_focus_y",
      "label": "Vertical position",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 50
    },
    { "type": "header", "content": "Mobile image position" },
    {
      "type": "range",
      "id": "mobile_focus_x",
      "label": "Horizontal position",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 50
    },
    {
      "type": "range",
      "id": "mobile_focus_y",
      "label": "Vertical position",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 40
    }
  ],
  "presets": [
    { "name": "Great Books hero" }
  ]
}
{% endschema %}
