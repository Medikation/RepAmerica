{{ 'rep-america-about.css' | asset_url | stylesheet_tag }}
<section class="ra-about ra-about-founder">
  <div class="ra-about__shell">
    <div class="ra-about-founder__grid">
      <div class="ra-about-founder__media">
        {%- if section.settings.image != blank -%}
          {{
            section.settings.image
            | image_url: width: 1400
            | image_tag:
              loading: 'lazy',
              widths: '500, 800, 1100, 1400',
              sizes: '(min-width: 901px) 40vw, 100vw',
              alt: section.settings.image.alt
          }}
        {%- endif -%}
      </div>

      <div>
        <p class="ra-about__eyebrow">{{ section.settings.eyebrow | escape }}</p>
        <h2 class="ra-about__section-heading">{{ section.settings.heading | escape }}</h2>
        <div class="ra-about__body">{{ section.settings.body }}</div>

        <div class="ra-about-founder__signature">
          <strong>{{ section.settings.name | escape }}</strong>
          <span>{{ section.settings.role | escape }}</span>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name":"About founder",
  "tag":"section",
  "settings":[
    {"type":"text","id":"eyebrow","label":"Eyebrow","default":"Founder"},
    {"type":"text","id":"heading","label":"Heading","default":"Built by Medi Hashemi."},
    {"type":"richtext","id":"body","label":"Body","default":"<p>Rep America began as independent commentary and is growing into a broader American media and commerce company rooted in strength, responsibility, and action.</p><p>The ambition is long-term: build an enduring institution that informs people, elevates serious ideas, supports builders, and helps create stronger Americans.</p>"},
    {"type":"image_picker","id":"image","label":"Founder image"},
    {"type":"text","id":"name","label":"Name","default":"Medi Hashemi"},
    {"type":"text","id":"role","label":"Role","default":"Founder, Rep America"}
  ],
  "presets":[{"name":"About founder"}]
}
{% endschema %}
