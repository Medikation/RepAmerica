{% doc %}
  @prompt
    separater
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-separator-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.spacing_top }}px 0 {{ block.settings.spacing_bottom }}px;
  }

  .ai-separator-line-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    margin: 0 auto;
    height: {{ block.settings.line_thickness }}px;
    {% if block.settings.separator_style == 'solid' %}
      background-color: {{ block.settings.line_color }};
    {% elsif block.settings.separator_style == 'gradient' %}
      background: linear-gradient(to right, transparent, {{ block.settings.line_color }}, transparent);
    {% elsif block.settings.separator_style == 'dashed' %}
      border-top: {{ block.settings.line_thickness }}px dashed {{ block.settings.line_color }};
      height: 0;
    {% elsif block.settings.separator_style == 'dotted' %}
      border-top: {{ block.settings.line_thickness }}px dotted {{ block.settings.line_color }};
      height: 0;
    {% endif %}
    border-radius: {{ block.settings.line_thickness | divided_by: 2.0 }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-separator-line-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<separator-block-{{ ai_gen_id }} class="ai-separator-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-separator-line-{{ ai_gen_id }}"></div>
</separator-block-{{ ai_gen_id }}>

<script>
  (function() {
    class SeparatorBlock{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }
    }
    customElements.define('separator-block-{{ ai_gen_id }}', SeparatorBlock{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Separator",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "select",
      "id": "separator_style",
      "label": "Style",
      "options": [
        {
          "value": "solid",
          "label": "Solid"
        },
        {
          "value": "gradient",
          "label": "Gradient"
        },
        {
          "value": "dashed",
          "label": "Dashed"
        },
        {
          "value": "dotted",
          "label": "Dotted"
        }
      ],
      "default": "solid"
    },
    {
      "type": "range",
      "id": "line_thickness",
      "label": "Thickness",
      "min": 1,
      "max": 10,
      "step": 1,
      "unit": "px",
      "default": 1
    },
    {
      "type": "color",
      "id": "line_color",
      "label": "Color",
      "default": "#121212"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "spacing_top",
      "label": "Top spacing",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "spacing_bottom",
      "label": "Bottom spacing",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "Separator"
    }
  ]
}
{% endschema %}
